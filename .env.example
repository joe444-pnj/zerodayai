# ─────────────────────────────────────────
#  ZeroDay AI — Environment Variables Template
# ─────────────────────────────────────────

# Ollama configuration (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=zeroday-ai:latest

# NVD API key for higher rate limits and faster CVE fetching
# Get one at: https://nvd.nist.gov/developers/request-api-key
NVD_API_KEY=your_nvd_api_key_here

# Dashboard API secret
API_SECRET_KEY=change-me-to-a-random-secret

# Debug mode
DEBUG=false
LOG_LEVEL=INFO
